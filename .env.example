# Database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/pulse_mind?schema=public"

# App
NEXT_PUBLIC_APP_URL="https://your-domain.com"
AUTH_URL="https://your-domain.com"
AUTH_SECRET="generate-a-random-secret-here"

# GitHub OAuth
GITHUB_CLIENT_ID="your-github-oauth-client-id"
GITHUB_CLIENT_SECRET="your-github-oauth-client-secret"

# Admin GitHub IDs (comma-separated)
ADMIN_GITHUB_IDS="your-github-user-id"

# Direct OpenAI news ingestion (optional fallback, not required for Codex Cloud flow)
OPENAI_API_KEY="your-openai-api-key"
OPENAI_MODEL="gpt-5.5"
OPENAI_REASONING_EFFORT="medium"
OPENAI_MAX_OUTPUT_TOKENS="2400"
OPENAI_TIMEOUT_MS="120000"
NEWS_MAX_ITEMS="5"
NEWS_RSS_TIMEOUT_MS="10000"
PUBLISH_NEWS="true"

# Codex Cloud news workflow
CODEX_NEWS_ARTICLE_LENGTH="900-1200 Chinese characters"
CODEX_NEWS_TARGET_DIR="content/articles"

# Internal article import webhook used by GitHub Actions
ARTICLE_IMPORT_URL="https://your-domain.com/api/internal/articles/import"
ARTICLE_IMPORT_SECRET="generate-a-random-secret-here"
